{
  "name": "panorama-music",
  "version": "0.0.1",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "panorama-music",
      "version": "0.0.1",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20.0.0"
      }
    },
    "node_modules/@panorama/backend": {
      "resolved": "packages/backend",
      "link": true
    },
    "node_modules/@panorama/frontend": {
      "resolved": "packages/frontend",
      "link": true
    },
    "packages/backend": {
      "name": "@panorama/backend",
      "version": "0.0.1"
    },
    "packages/frontend": {
      "name": "@panorama/frontend",
      "version": "0.0.1"
    }
  }
}
