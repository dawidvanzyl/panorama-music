{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Auth": {
      "IpPermitLimit": 10,
      "AccountPermitLimit": 10,
      "WindowSeconds": 60
    }
  }
}
