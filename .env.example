# PostgreSQL credentials (used by both dev and qa profiles)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database names per profile
POSTGRES_DB_DEV=panorama_music_dev
POSTGRES_DB_QA=panorama_music_qa

# Set to true to wipe the QA database, re-run all migrations, and re-seed on
# the next `docker compose --profile qa up` start. Reset to false afterwards.
# Never set to true in production.
RESET_DB=false

# JWT signing secret (min 32 characters)
JWT__Secret=change-me-to-a-secret-at-least-32-chars-long!!

# JWT issuer/audience pinned during validation, and the absolute session
# lifetime cap (in days) enforced independently of refresh-token rotation
JWT__Issuer=panorama-music-api
JWT__Audience=panorama-music-client
JWT__AbsoluteSessionLifetimeDays=30

# Admin seed credentials (used when RESET_DB=true or when no admin exists)
Admin__Email=admin@panorama-music.com
Admin__Password=ChangeMe123!

# Auth rate limits for the qa profile (relaxed so the E2E suite doesn't blow
# past production-strength limits within a single Playwright run)
RateLimiting__Auth__IpPermitLimit=1000
RateLimiting__Auth__AccountPermitLimit=1000
RateLimiting__Auth__WindowSeconds=60

# SMTP target for the qa profile (smtp4dev, no auth required)
Smtp__Host=smtp4dev
Smtp__Port=25
Smtp__From=noreply@panorama-music.qa
Smtp__FromDisplayName=Panorama Music (QA)

# Base URL used to build links in emails (password reset, invites) sent by
# the qa profile
AppBaseUrl=http://localhost:3000

# Set to true to make the qa profile call the live HIBP Pwned-Passwords API
# instead of skipping it (skipped by default so E2E CI doesn't depend on a
# third party). Never affects dev — Hibp is always live there.
Hibp__Enabled=false
