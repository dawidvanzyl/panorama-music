# PostgreSQL credentials (used by both dev and qa profiles)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Database names per profile
POSTGRES_DB_DEV=panorama_music_dev
POSTGRES_DB_QA=panorama_music_qa

# Set to true to wipe the QA database, re-run all migrations, and re-seed on
# the next `docker compose --profile qa up` start. Reset to false afterwards.
# Never set to true in production.
RESET_DB=false
